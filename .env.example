# LLM Provider：默认走百炼 OpenAI-compatible；真实密钥只放本地 .env，不要提交。
SEEKTALENT_TEXT_LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# CTS：真实简历搜索接口配置；本地 smoke 可用 SEEKTALENT_MOCK_CTS=true 绕过。
SEEKTALENT_CTS_BASE_URL=https://link.hewa.cn
SEEKTALENT_CTS_TENANT_KEY=
SEEKTALENT_CTS_TENANT_SECRET=
SEEKTALENT_CTS_TIMEOUT_SECONDS=20
SEEKTALENT_CTS_SPEC_PATH=cts.validated.yaml

# Provider：默认仍使用 CTS；切到 Liepin 时必须显式选择 worker 模式。
SEEKTALENT_PROVIDER_NAME=cts
# Liepin worker 模式：disabled 不可被选为 active provider；managed_local 是本地可直播默认路径。
SEEKTALENT_LIEPIN_WORKER_MODE=disabled
# fake_fixture 只给边界测试用，必须显式允许，避免误把假数据当真实搜索。
SEEKTALENT_LIEPIN_ALLOW_FAKE_FIXTURE_WORKER=false
# 外部 HTTP worker：liepin_worker_mode=external_http 时必须填写；managed_local 不需要预置 URL。
SEEKTALENT_LIEPIN_WORKER_BASE_URL=
SEEKTALENT_LIEPIN_WORKER_HOST=127.0.0.1
SEEKTALENT_LIEPIN_WORKER_PORT=0
SEEKTALENT_LIEPIN_WORKER_STARTUP_TIMEOUT_SECONDS=15.0
SEEKTALENT_LIEPIN_WORKER_TIMEOUT_SECONDS=30.0
SEEKTALENT_LIEPIN_CONNECTOR_DB_PATH=.seektalent/liepin_connector.sqlite3
# Liepin session store：本地保存登录会话素材；key id 只是本地开发标识，不代表生产密钥。
SEEKTALENT_LIEPIN_SESSION_STORE_DIR=.seektalent/liepin_sessions
SEEKTALENT_LIEPIN_SESSION_STORE_KEY_ID=local-development
SEEKTALENT_LIEPIN_API_TOKEN=local-development-liepin-api-token
# Detail open approval：Python reserve 详情预算后签发，worker 只接受签名后的 approval key。
SEEKTALENT_LIEPIN_DETAIL_OPEN_APPROVAL_SECRET=
# Detail budget：每日详情页打开预算；0 表示不打开详情，不能为负数。
SEEKTALENT_LIEPIN_DEFAULT_DAILY_DETAIL_BUDGET=20
# Live gate：默认禁止真实 Liepin 行为，后续 live connector 任务必须显式打开。
SEEKTALENT_LIEPIN_LIVE_ENABLED=false

# Text LLM：默认协议已切回百炼 OpenAI-compatible；Anthropic-compatible 只作为显式兼容路径保留。
SEEKTALENT_TEXT_LLM_PROTOCOL_FAMILY=openai_chat_completions_compatible
SEEKTALENT_TEXT_LLM_PROVIDER_LABEL=bailian
SEEKTALENT_TEXT_LLM_ENDPOINT_KIND=bailian_openai_chat_completions
SEEKTALENT_TEXT_LLM_ENDPOINT_REGION=beijing
SEEKTALENT_TEXT_LLM_BASE_URL_OVERRIDE=

# Stage models：judge/eval 使用百炼 deepseek-v4-pro；高频执行阶段默认用 deepseek-v4-flash。
SEEKTALENT_REQUIREMENTS_MODEL_ID=deepseek-v4-pro
SEEKTALENT_CONTROLLER_MODEL_ID=deepseek-v4-pro
SEEKTALENT_SCORING_MODEL_ID=deepseek-v4-flash
SEEKTALENT_FINALIZE_MODEL_ID=deepseek-v4-flash
SEEKTALENT_REFLECTION_MODEL_ID=deepseek-v4-pro
SEEKTALENT_REQUIREMENTS_ENABLE_THINKING=true
SEEKTALENT_STRUCTURED_REPAIR_MODEL_ID=deepseek-v4-flash
SEEKTALENT_STRUCTURED_REPAIR_REASONING_EFFORT=off
SEEKTALENT_JUDGE_MODEL_ID=deepseek-v4-pro
SEEKTALENT_TUI_SUMMARY_MODEL_ID=
SEEKTALENT_REASONING_EFFORT=off
SEEKTALENT_JUDGE_REASONING_EFFORT=high
SEEKTALENT_CONTROLLER_ENABLE_THINKING=true
SEEKTALENT_REFLECTION_ENABLE_THINKING=true

# Candidate feedback rescue：active 低质量 rescue 仍是确定性路径；这里的模型配置只保留给 dormant model-ranked 扩展点。
SEEKTALENT_CANDIDATE_FEEDBACK_ENABLED=true
SEEKTALENT_CANDIDATE_FEEDBACK_MODEL_ID=deepseek-v4-flash
SEEKTALENT_CANDIDATE_FEEDBACK_REASONING_EFFORT=off

# LLM PRF 只做候选短语 proposal；最终是否进入第二路由 deterministic grounding / policy 决定。
SEEKTALENT_PRF_PROBE_PHRASE_PROPOSAL_MODEL_ID=deepseek-v4-flash
SEEKTALENT_PRF_PROBE_PHRASE_PROPOSAL_REASONING_EFFORT=off
# 主路径默认 3 秒，避免 PRF proposal 拖慢 exploit lane；live harness 可单独放宽到 30 秒。
SEEKTALENT_PRF_PROBE_PHRASE_PROPOSAL_TIMEOUT_SECONDS=3.0
SEEKTALENT_PRF_PROBE_PHRASE_PROPOSAL_LIVE_HARNESS_TIMEOUT_SECONDS=30.0
# 防止 JSON 结构输出被截断；不是 provider retry。
SEEKTALENT_PRF_PROBE_PHRASE_PROPOSAL_MAX_OUTPUT_TOKENS=2048

# Runtime：轮次、并发、缓存和输出目录；空值表示使用代码默认路径。
SEEKTALENT_MIN_ROUNDS=3
SEEKTALENT_MAX_ROUNDS=10
SEEKTALENT_SCORING_MAX_CONCURRENCY=5
SEEKTALENT_JUDGE_MAX_CONCURRENCY=5
SEEKTALENT_SEARCH_MAX_PAGES_PER_ROUND=3
SEEKTALENT_SEARCH_MAX_ATTEMPTS_PER_ROUND=3
SEEKTALENT_SEARCH_NO_PROGRESS_LIMIT=2
SEEKTALENT_RUNTIME_MODE=dev
SEEKTALENT_WORKSPACE_ROOT=
SEEKTALENT_ARTIFACTS_DIR=
SEEKTALENT_LLM_CACHE_DIR=.seektalent/cache
# Query Rewriting Data Flywheel 本地 SQLite 索引库；原始轨迹仍保存在 artifacts/。
SEEKTALENT_FLYWHEEL_DB_PATH=.seektalent/flywheel.sqlite3
# Corpus 资产库：保存 JD、所有 provider 返回的简历快照、观察记录和后续搜索/benchmark 的基础资产。
# 默认写到本地工作区 .seektalent/corpus.sqlite3；不要把它和 flywheel.sqlite3 混用。
SEEKTALENT_CORPUS_DB_PATH=.seektalent/corpus.sqlite3
SEEKTALENT_RUNS_DIR=runs
SEEKTALENT_OPENAI_PROMPT_CACHE_ENABLED=false
SEEKTALENT_OPENAI_PROMPT_CACHE_RETENTION=
SEEKTALENT_MOCK_CTS=false
SEEKTALENT_ENABLE_REFLECTION=true

# Eval：默认关闭；开启后 judge/eval 使用百炼 deepseek-v4-pro。
SEEKTALENT_ENABLE_EVAL=false
SEEKTALENT_WANDB_ENTITY=frankqdwang1-personal-creations
SEEKTALENT_WANDB_PROJECT=seektalent
SEEKTALENT_WEAVE_ENTITY=frankqdwang1-personal-creations
SEEKTALENT_WEAVE_PROJECT=seektalent
