{
	"name": "web-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1 --port 5178 --strictPort",
		"dev:e2e": "vite --host 127.0.0.1 --port 5179 --strictPort",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1 --port 4178 --strictPort",
		"preview:e2e": "vite preview --host 127.0.0.1 --port 5179 --strictPort",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"api:gen": "openapi-typescript http://127.0.0.1:8012/openapi.json -o src/lib/api/schema.d.ts && prettier --write src/lib/api/schema.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.3",
		"@jackwener/opencli": "1.8.0",
		"@tanstack/svelte-query": "^6.1.29",
		"@xyflow/svelte": "^1.5.2",
		"elkjs": "^0.11.1",
		"openapi-fetch": "^0.17.0",
		"pi-mcp-adapter": "2.6.1",
		"typebox": "1.1.38"
	}
}
